{
  "name": "goods-price-comparison-api",
  "version": "1.0.0",
  "description": "OpenAPI specification project",
  "devDependencies": {
    "@redocly/cli": "^1.28.0",
    "js-yaml": "^4.1.1",
    "openapi-to-postmanv2": "^4.23.0"
  },
  "scripts": {
    "bundle": "redocly bundle src/main/resources/openapi/main.yaml --output src/main/resources/openapi/openapi-bundled.yaml",
    "generate-postman": "openapi2postmanv2 -s src/main/resources/openapi/openapi-bundled.yaml -o target/postman-collection.json",
    "inject-postman-tests": "node scripts/inject-postman-tests.js target/postman-collection.json",
    "generate-postman-env": "node scripts/generate-postman-env.js",
    "generate-vercel-routes": "node scripts/generate-vercel-routes.js"
  }
}
